<Window x:Class="StockExchangeSimulator.Views.VirtualMarketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Виртуальный рынок" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="BalanceText"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0 0 0 15"/>

        <DataGrid x:Name="AssetsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0 0 0 15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тикер" Binding="{Binding Ticker}" Width="*"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding CurrentPrice}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBox x:Name="QuantityTextBox" Width="100" Height="30" Margin="0 0 10 0" Text="1"/>
            <Button Content="Купить" Width="120" Height="30" Margin="0 0 10 0" Click="Buy_Click"/>
            <Button Content="Продать" Width="120" Height="30" Click="Sell_Click"/>
        </StackPanel>
    </Grid>
</Window>