<Window x:Class="StockExchangeSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Симулятор фондовой биржи" Height="350" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="Симулятор фондовой биржи"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 30"/>

            <Button Content="Режим реальных акций"
                    Height="45"
                    Margin="0 0 0 15"
                    Click="OpenRealMarket_Click"/>

            <Button Content="Режим виртуального рынка"
                    Height="45"
                    Margin="0 0 0 15"
                    Click="OpenVirtualMarket_Click"/>

            <Button Content="Выход"
                    Height="45"
                    Click="Exit_Click"/>

        </StackPanel>
    </Grid>
</Window>