<Window x:Class="StockExchangeSimulator.Views.RealMarketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Реальный рынок"
        Height="860"
        Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                Margin="0 0 0 10"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <WrapPanel Margin="0 0 0 8">
                    <TextBlock x:Name="BalanceText" FontSize="16" FontWeight="Bold" Margin="0 0 25 0"/>
                    <TextBlock x:Name="PositionsValueText" FontSize="16" Margin="0 0 25 0"/>
                    <TextBlock x:Name="TotalValueText" FontSize="16" Margin="0 0 25 0"/>
                    <TextBlock x:Name="TotalPnLText" FontSize="16"/>
                </WrapPanel>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Количество:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <TextBox x:Name="QuantityTextBox" Width="90" Margin="0 0 12 0"/>

                    <Button x:Name="BuyButton" Content="Купить" Width="100" Margin="0 0 8 0" Click="Buy_Click"/>
                    <Button x:Name="SellButton" Content="Продать" Width="100" Margin="0 0 16 0" Click="Sell_Click"/>

                    <TextBlock Text="Тикер:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <TextBox x:Name="TickerTextBox" Width="120" Margin="0 0 8 0"/>
                    <Button Content="Добавить тикер" Width="130" Margin="0 0 8 0" Click="AddTicker_Click"/>
                    <Button Content="Удалить тикер" Width="130" Margin="0 0 16 0" Click="RemoveTicker_Click"/>

                    <Button Content="Обновить сейчас" Width="130" Margin="0 0 12 0" Click="RefreshNow_Click"/>

                    <CheckBox x:Name="AutoUpdateCheckBox"
                              Content="Автообновление"
                              VerticalAlignment="Center"
                              Margin="0 0 8 0"
                              Checked="AutoUpdateCheckBox_Checked"
                              Unchecked="AutoUpdateCheckBox_Unchecked"/>

                    <TextBlock Text="Интервал:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <ComboBox x:Name="RefreshIntervalComboBox"
                              Width="90"
                              Margin="0 0 16 0"
                              SelectionChanged="RefreshIntervalComboBox_SelectionChanged">
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="15"/>
                        <ComboBoxItem Content="30"/>
                        <ComboBoxItem Content="60"/>
                    </ComboBox>

                    <TextBlock Text="Статус:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0 0 6 0"/>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="Котировки" FontSize="16" FontWeight="Bold" Margin="0 0 0 6"/>

        <DataGrid x:Name="AssetsGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="AssetsGrid_SelectionChanged"
                  Margin="0 0 0 12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тикер" Binding="{Binding Ticker}" Width="*"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding CurrentPrice, StringFormat=F2}" Width="*"/>
                <DataGridTextColumn Header="Изм." Binding="{Binding Change, StringFormat=F2}" Width="*"/>
                <DataGridTextColumn Header="% изм." Binding="{Binding ChangePercent, StringFormat=F2}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="Позиции" FontSize="16" FontWeight="Bold" Margin="0 0 0 6"/>

        <DataGrid x:Name="PositionsGrid"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0 0 0 12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тикер" Binding="{Binding Ticker}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="*"/>
                <DataGridTextColumn Header="Средняя цена" Binding="{Binding AveragePrice, StringFormat=F2}" Width="*"/>
                <DataGridTextColumn Header="Текущая цена" Binding="{Binding CurrentPrice, StringFormat=F2}" Width="*"/>
                <DataGridTextColumn Header="Стоимость" Binding="{Binding MarketValue, StringFormat=F2}" Width="*"/>
                <DataGridTextColumn Header="PnL" Binding="{Binding PnL, StringFormat=F2}" Width="*"/>
                <DataGridTextColumn Header="PnL %" Binding="{Binding PnLPercent, StringFormat=F2}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="5" Text="История сделок" FontSize="16" FontWeight="Bold" Margin="0 0 0 6"/>

        <DataGrid x:Name="TradesGrid"
                  Grid.Row="6"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0 0 0 12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Время" Binding="{Binding Timestamp, StringFormat=dd.MM.yyyy HH:mm:ss}" Width="1.7*"/>
                <DataGridTextColumn Header="Тикер" Binding="{Binding Ticker}" Width="*"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding TradeType}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=F2}" Width="*"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=F2}" Width="*"/>
                <DataGridTextColumn Header="Рынок" Binding="{Binding MarketMode}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="LastUpdateText"
                   Grid.Row="7"
                   HorizontalAlignment="Right"
                   FontStyle="Italic"/>
    </Grid>
</Window>